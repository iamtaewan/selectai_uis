# Select AI Demo Studio — 백엔드 환경변수 (architecture.md §6.3)
# 비밀(DB 비밀번호 등)은 .env가 아닌 ~/.selectai/connections.json에 Fernet 암호화 저장.

# 앱 일반
APP_ENV=local                       # local / prod (로그 레벨·문서 노출 제어)
#APP_SECRET_KEY=                    # Fernet 키 — 미설정 시 ~/.selectai/secret.key 자동 생성
APP_DATA_DIR=~/.selectai            # 앱 데이터 디렉토리 (wallets/·*.json·secret.key, 0700)

# OCI CLI (wallet 자동 다운로드)
OCI_CLI_PROFILE=DEFAULT

# DB 풀/타임아웃
DB_POOL_MAX=4
DB_CALL_TIMEOUT_MS=15000            # 일반 쿼리 call_timeout
SELECTAI_CALL_TIMEOUT_MS=120000     # GENERATE 계열 call_timeout 상한

# 프로파일 기본값 (TAEWAN.KIM 컴파트먼트 — CLAUDE.md 전역 규칙)
DEFAULT_OCI_COMPARTMENT_ID=ocid1.compartment.oc1..<your-compartment-ocid>
DEFAULT_OCI_REGION=us-chicago-1
DEFAULT_MODEL=meta.llama-3.3-70b-instruct

# 대화 기본 보관일 (오픈 이슈 O4)
CONVERSATION_RETENTION_DAYS=7
